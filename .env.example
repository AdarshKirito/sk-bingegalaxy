# ============================================================
# SK Binge Galaxy — Environment Variables
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control.
# ============================================================

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=          # REQUIRED — PostgreSQL password for skbg_admin
MONGO_PASSWORD=             # REQUIRED — MongoDB root password

# ── Service Discovery ────────────────────────────────────────
EUREKA_PASSWORD=            # REQUIRED — Eureka Basic Auth password

# ── Config Server ────────────────────────────────────────────
CONFIG_SERVER_USER=configuser
CONFIG_SERVER_PASSWORD=     # REQUIRED — Spring Cloud Config password

# ── JWT ───────────────────────────────────────────────────────
# Base64-encoded HMAC-SHA256 key (min 256 bits / 32 bytes)
JWT_SECRET=                 # REQUIRED — generate with: openssl rand -base64 32

# ── Internal Service-to-Service Auth ──────────────────────────
INTERNAL_API_SECRET=        # REQUIRED — shared secret for Feign calls: openssl rand -hex 32

# ── Deploy / Ingress ──────────────────────────────────────────
INGRESS_HOST=skbingegalaxy.com
TLS_SECRET_NAME=skbingegalaxy-tls
LETSENCRYPT_EMAIL=admin@skbingegalaxy.com
STORAGE_CLASS_NAME=         # REQUIRED for Kubernetes stateful workloads

# ── Auth Cookies ──────────────────────────────────────────────
COOKIE_SECURE=true           # Set to false only for local HTTP development
COOKIE_DOMAIN=               # Set to your production domain when using ingress

# ── Admin Seeding ─────────────────────────────────────────────
ADMIN_EMAIL=admin@skbingegalaxy.com
ADMIN_PASSWORD=             # REQUIRED — strong initial admin password

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=           # REQUIRED — Google OAuth 2.0 client ID

# ── Payment ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=            # REQUIRED — Razorpay API key ID
RAZORPAY_KEY_SECRET=        # REQUIRED — Razorpay API key secret
PAYMENT_CALLBACK_URL=       # e.g. https://yourdomain.com/api/v1/payments/callback

# ── CORS (comma-separated origins) ───────────────────────────
CORS_ALLOWED_ORIGINS=https://skbingegalaxy.com  # Add http://localhost:3000 only for local dev

# ── Email / SMTP ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=                 # SMTP username
EMAIL_PASS=                 # SMTP password / app-specific password
EMAIL_FROM=noreply@skbingegalaxy.com

# ── SMS / WhatsApp ────────────────────────────────────────────
SMS_PROVIDER=disabled        # Use a real provider name only after integration exists
SMS_API_KEY=
WHATSAPP_PROVIDER=disabled   # Use a real provider name only after integration exists
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
