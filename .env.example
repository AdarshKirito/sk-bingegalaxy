# ============================================================
# SK Binge Galaxy — Environment Variables
# Copy this file to .env and update values for your environment
# ============================================================

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=skbg_secret
MONGO_PASSWORD=skbg_secret

# ── JWT ───────────────────────────────────────────────────────
# Base64-encoded HMAC-SHA256 key (min 256 bits / 32 bytes)
JWT_SECRET=c2tiLWJpbmdlLWdhbGF4eS1zdXBlci1zZWNyZXQta2V5LXByb2R1Y3Rpb24tY2hhbmdlLXRoaXM=

# ── Admin Seeding ─────────────────────────────────────────────
ADMIN_EMAIL=admin@sk.com
ADMIN_PASSWORD=Admin@123

# ── CORS (comma-separated origins) ───────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Email / SMTP ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Kafka ─────────────────────────────────────────────────────
# Only override if Kafka runs outside Docker Compose
# KAFKA_BOOTSTRAP_SERVERS=kafka:29092
